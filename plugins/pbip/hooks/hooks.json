{
  "description": "Validates PBIP project files (JSON syntax + TMDL structure) after Write/Edit and Bash modifications",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-pbip-json.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-tmdl.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-pbir-bash.sh",
            "timeout": 10,
            "if": "Bash(*.Report/*)"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-tmdl-bash.sh",
            "timeout": 10,
            "if": "Bash(*.tmdl*)"
          }
        ]
      }
    ]
  }
}
